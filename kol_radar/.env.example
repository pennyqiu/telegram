# ════════════════════════════════════════════════════════════════════
#  kol_radar 环境变量（复制为 .env 后填值；.env 已在 .gitignore 不会提交）
# ════════════════════════════════════════════════════════════════════

# ── 首选数据源后端：x_api | nitter | rsshub（失败会自动按顺序降级） ──
KOL_SOURCE=x_api

# ── 后端 1：X 官方 API v2（最稳、质量最高，推荐） ──
# 2026-02 起官方取消免费层，改为「按量付费」：读取约 $0.005/条，无月最低消费。
# 本工具用量极低（6 KOL×8 条≈48 读/次，约 $0.24/次），每天跑一次约 $7/月。
# 注册：https://console.x.com → 建 App → Keys and tokens → 生成 Bearer Token
X_BEARER_TOKEN=

# ── 后端 2：Nitter 实例 RSS（免费；公共实例经常挂，建议自建） ──
# 例：https://nitter.poast.org  （会拼成 {NITTER_BASE}/{handle}/rss）
NITTER_BASE=

# ── 后端 3：RSSHub 实例（免费/自建；路由 /twitter/user/:handle） ──
# 公共实例 https://rsshub.app 经常限流，强烈建议自建后改这里
RSSHUB_BASE=https://rsshub.app
# 自建 RSSHub 若开了访问密钥，填这里（会拼成 ?key=...）
RSSHUB_KEY=
