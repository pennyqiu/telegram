# ── Telegram 配置（复用现有 Bot） ─────────────────────────────────
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 接收告警的 Chat ID（私聊/群组/频道均可，负数为群组）
ALERT_CHAT_ID=123456789

# ── IB Gateway 连接 ────────────────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=4001                  # 实盘 Gateway 端口（模拟盘用 4002）
IB_CLIENT_ID=10               # 只读监控专用 Client ID，避免与其他客户端冲突
IB_ACCOUNT=U12345678          # 你的 IB 账户号

# ── 风控阈值 ───────────────────────────────────────────────────────
# 剩余流动性（占 NLV 比例）
EXCESS_LIQUIDITY_WARN=0.50    # 50% 黄色预警
EXCESS_LIQUIDITY_RED=0.40     # 40% 红线（跌破立即告警+禁止开仓提示）

# 单股集中度（占 NLV 比例）
CONCENTRATION_WARN=0.27       # 27% 黄色预警
CONCENTRATION_RED=0.30        # 30% 红线

# Gamma 死亡警戒线
GAMMA_DTE_THRESHOLD=14        # DTE 小于此值触发扫描
GAMMA_DELTA_MIN=0.30          # ATM 判定范围：|delta| 下限
GAMMA_DELTA_MAX=0.70          # ATM 判定范围：|delta| 上限

# ── CC 展期与止盈配置 ──────────────────────────────────────────────
# 空头 Call Delta 超过此值触发展期告警（默认适用所有标的）
CC_ROLL_DEFAULT_DELTA=0.40
# NVDA 单独配置更激进的防御线
CC_ROLL_NVDA_DELTA=0.35
# CC 止盈线：盈利超过初始权利金此比例时触发平仓建议
CC_PROFIT_TAKE_PCT=0.50

# ── 标的积攒目标 ────────────────────────────────────────────────────
# SPYM 积攒目标股数（达到后触发 VOO Swap 提醒）
SPYM_TARGET=844
# SPYM → VOO 置换比例（844股SPYM ≈ 110股VOO，即每股VOO约需7.67股SPYM）
SPYM_TO_VOO_RATIO=0.1303

# ── 监控频率 ────────────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=60     # 实时风控检查间隔（秒）
DAILY_REPORT_HOUR=8           # 每日健康报告时间（北京时间，小时）
DAILY_REPORT_MINUTE=30        # 每日健康报告时间（分钟）
