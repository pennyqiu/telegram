CLUB_DB_URL=postgresql+asyncpg://user:pass@db:5432/tg_club
REDIS_URL=redis://redis:6379/0

# 管理后台账号
ADMIN_JWT_SECRET=change_this_admin_jwt_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# 管理后台 Web 地址（Bot 内联按钮跳转用）
ADMIN_WEB_URL=https://admin.yourdomain.com

# Telegram 俱乐部查询 Bot（从 @BotFather 创建第二个 Bot 获取）
CLUB_BOT_TOKEN=7xxxxxxxxx:BBxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLUB_BOT_WEBHOOK_URL=https://club.yourdomain.com/webhooks/telegram
CLUB_BOT_WEBHOOK_SECRET=your_random_32char_string

# 管理员 Telegram ID（逗号分隔，可在 @userinfobot 获取）
ADMIN_TELEGRAM_IDS=123456789,987654321

# 对接订阅系统（唯一耦合点：HTTP 调用）
SUBSCRIPTION_SERVICE_URL=http://tg-subscription:8000
SUBSCRIPTION_INTERNAL_API_KEY=change_this_internal_api_key

# Cloudflare R2 图片存储（可选，留空跳过）
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=club-assets
R2_PUBLIC_URL=https://assets.yourdomain.com
