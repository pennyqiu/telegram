# ════════════════════════════════════════════════════════════════════
#  ib_quant 量化交易模块 环境变量
#  复制为 .env 后填入真实值（.env 已在 .gitignore，切勿提交）
# ════════════════════════════════════════════════════════════════════

# ── Telegram 通知（可复用 ib_monitor 的同一个 Bot） ──────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789          # 接收交易通知的 Chat ID

# ── 邮箱通知（可选，作为 Telegram 之外的备用触达通道） ───────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your_app_specific_password   # Gmail 需用「应用专用密码」
EMAIL_SENDER=you@gmail.com
EMAIL_RECIPIENTS=you@gmail.com,backup@qq.com   # 逗号分隔多个收件人

# ── IB Gateway 连接 ──────────────────────────────────────────────────
# 端口约定：4001=实盘API  4002=模拟盘API（容器内部为 4003/4004）
IB_HOST=127.0.0.1
IB_PORT=4002                        # 默认模拟盘；实盘改 4001
IB_CLIENT_ID=20                     # 交易客户端专用 ID（与只读监控 10 区分）
IB_ACCOUNT=DU1234567                # 模拟盘账户 DUxxxx / 实盘 Uxxxx
TRADING_MODE=paper                  # paper=模拟盘  live=实盘

# IB Gateway 登录（仅 docker-compose 自动登录时需要）
IB_USERNAME=your_ib_username
IB_PASSWORD=your_ib_password
# 服务器无人值守自动登录需将 IB 2FA 改为 TOTP，并填入 Base32 密钥
IB_TOTP_SECRET=

# ── 交易安全护栏（真实资金的最后一道防线） ────────────────────────────
DRY_RUN=true                        # true=只记录订单不真实发送（务必先跑通）
ALLOW_LIVE=false                    # 实盘二次开关：连实盘必须显式 true
SYMBOL_WHITELIST=AAPL,MSFT,NVDA     # 仅允许交易这些标的（空=不限制，不建议）
MAX_ORDER_NOTIONAL=5000             # 单笔订单名义金额上限（USD）
MAX_POSITION_NOTIONAL=20000         # 单标的累计持仓市值上限（USD）
MAX_DAILY_ORDERS=20                 # 单日最大下单笔数（防策略 bug 失控）
REQUIRE_CONFIRM=true                # 实盘下单是否需要 Telegram 人工二次确认

# ── 策略与调度 ────────────────────────────────────────────────────────
ENABLED_STRATEGIES=ma_cross         # 启用的策略（逗号分隔）
UNIVERSE=AAPL,MSFT,NVDA             # 策略关注的标的池
POLL_INTERVAL_SECONDS=60            # 周期性检查间隔（秒）
DAILY_REPORT_HOUR=8                 # 每日报告时间（北京时间，小时）
DAILY_REPORT_MINUTE=30

# ── Web 看板（量化策略切页） ──────────────────────────────────────────
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8800
