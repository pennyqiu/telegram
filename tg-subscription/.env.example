TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=change_this_to_random_32char_string
TELEGRAM_WEBHOOK_URL=https://api.your-domain.com/webhooks/telegram

MINI_APP_URL=https://your-subscription-mini-app.vercel.app

DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/tg_sub
REDIS_URL=redis://redis:6379/0

GRACE_PERIOD_DAYS=3
EXPIRY_REMINDER_DAYS=3
ADMIN_TELEGRAM_IDS=123456789

# 对外暴露给 tg-club 调用的 API 密钥
INTERNAL_API_KEY=change_this_internal_api_key

# ── 微信支付（留空则不启用） ───────────────────────────────────
# 前往 https://pay.weixin.qq.com 注册商户账号获取
WECHAT_APPID=wx1234567890abcdef
WECHAT_MCHID=1234567890
WECHAT_APIV3_KEY=your_32char_apiv3_key_here_xxxxxxx
# 私钥内容（apiclient_key.pem），将换行替换为 \n
WECHAT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkq...\n-----END PRIVATE KEY-----
WECHAT_CERT_SERIAL_NO=ABCDEF1234567890ABCDEF1234567890ABCDEF12
WECHAT_NOTIFY_URL=https://api.your-domain.com/webhooks/wechat

# ── 支付宝（留空则不启用） ────────────────────────────────────
# 前往 https://open.alipay.com 创建应用获取
ALIPAY_APP_ID=2021000112345678
# 应用私钥（RSA2 格式，非 PKCS8 时需转换）
ALIPAY_PRIVATE_KEY=MIIEvQIBADANBgkqhkiG9w0BAQEFAASC...
# 支付宝公钥（从开放平台「应用信息」中复制）
ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOC...
ALIPAY_NOTIFY_URL=https://api.your-domain.com/webhooks/alipay

# ── 虎皮椒聚合支付（推荐个人开发者首选，无需营业执照）─────────────
# 注册地址：https://www.xunhupay.com
# 填入后自动覆盖微信/支付宝官方直连，留空则走上方官方 SDK
XUNHUPAY_APPID=your_xunhupay_appid
XUNHUPAY_APPSECRET=your_xunhupay_appsecret
XUNHUPAY_NOTIFY_URL=https://api.your-domain.com/webhooks/xunhupay

# ── 课程内容交付 ───────────────────────────────────────────────
# 付费成功后 Bot 发给用户的课程访问地址
# 推荐托管到 GitHub Pages 或 Vercel（免费 HTTPS）
COURSE_URL=https://yourname.github.io/us-stock-learning

# ── OpenAI（播客翻译 + 普通话 TTS）──────────────────────────────
# 前往 https://platform.openai.com/api-keys 创建
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：gpt-4o-mini（默认，便宜快速）/ gpt-4o（更高质量）
# OPENAI_TRANSLATE_MODEL=gpt-4o-mini
# 可选 TTS 声音：nova（自然女声，推荐）/ shimmer / alloy / echo / fable / onyx
# OPENAI_TTS_VOICE=nova
